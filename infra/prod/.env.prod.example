# Este arquivo serve como referência para criar o secret PROD_ENV_FILE no GitHub.
# Copie o conteúdo daqui, preencha os valores reais e salve como secret.
# GitHub > Settings > Secrets and variables > Actions > New repository secret
# Nome: PROD_ENV_FILE

APP_NAME=OficinaManager
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=manager
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=oficina_manager
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
