APP_IMAGE=ghcr.io/OWNER/oficina-manager-app-app:latest
WEB_IMAGE=ghcr.io/OWNER/oficina-manager-app-web:latest

APP_NAME=OficinaManager
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=manager
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=oficina_manager
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
